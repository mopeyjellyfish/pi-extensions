{
  "name": "@mopeyjellyfish/pi-web-search",
  "version": "1.0.0",
  "description": "Provider-native web search for Pi using the current or a configured model.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.20.0"
  },
  "files": [
    "src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-extension",
    "pi-package",
    "web-search",
    "openai",
    "anthropic"
  ],
  "devDependencies": {
    "vitest": "4.1.10"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mopeyjellyfish/pi-extensions.git",
    "directory": "packages/web-search"
  },
  "scripts": {
    "test": "vitest run --root ../.. packages/web-search/test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
