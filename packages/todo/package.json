{
  "name": "@mopeyjellyfish/pi-todo",
  "version": "0.0.0",
  "description": "Session-aware todo tracking for Pi agents.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.20.0"
  },
  "files": [
    "src/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-extension",
    "pi-package",
    "todo",
    "task-list"
  ],
  "devDependencies": {
    "vitest": "4.1.10"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mopeyjellyfish/pi-extensions.git",
    "directory": "packages/todo"
  },
  "scripts": {
    "test": "vitest run --root ../.. packages/todo/test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
