{
  "name": "@mopeyjellyfish/pi-worktrunk",
  "version": "1.0.0",
  "description": "Safe Worktrunk worktree selection and transparent routing for Pi.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.20.0"
  },
  "files": [
    "src/",
    "skills/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-extension",
    "pi-package",
    "worktrunk",
    "worktree"
  ],
  "devDependencies": {
    "vitest": "4.1.10"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mopeyjellyfish/pi-extensions.git",
    "directory": "packages/worktrunk"
  },
  "scripts": {
    "test": "vitest run --root ../.. packages/worktrunk/test",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
