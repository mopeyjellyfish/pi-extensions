{
  "name": "@mopeyjellyfish/pi-extensions",
  "version": "0.0.0",
  "private": true,
  "description": "A rigorously tested monorepo of extensions for the Pi coding agent.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.20.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "pi": {
    "extensions": [
      "./packages/*/src/index.ts",
      "./node_modules/@ff-labs/pi-fff/src/index.ts"
    ],
    "skills": [
      "./packages/*/skills"
    ],
    "prompts": [
      "./packages/*/prompts"
    ]
  },
  "scripts": {
    "check": "npm run format:check && npm run lint && npm run markdownlint && npm run knip && npm run typecheck && npm run test:coverage && npm run packages:check && npm run smoke && npm run go:check",
    "commits:check": "commitlint --verbose",
    "fix": "npm run format && npm run lint:fix && npm run go:format",
    "format": "prettier --write --ignore-unknown .",
    "format:check": "prettier --check --ignore-unknown .",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "markdownlint": "markdownlint-cli2",
    "knip": "knip --no-config-hints",
    "typecheck": "tsx scripts/typecheck.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "packages:check": "tsx scripts/validate-packages.ts",
    "smoke": "tsx scripts/smoke-packages.ts",
    "smoke:source": "tsx scripts/smoke-packages.ts --source-only",
    "smoke:packed": "tsx scripts/smoke-packages.ts --packed-only",
    "go:verify": "tsx scripts/go.ts verify",
    "go:format": "tsx scripts/go.ts format",
    "go:format:check": "tsx scripts/go.ts format-check",
    "go:lint": "tsx scripts/go.ts lint",
    "go:test": "tsx scripts/go.ts test",
    "go:vuln": "tsx scripts/go.ts vuln",
    "go:check": "npm run go:verify && npm run go:format:check && npm run go:lint && npm run go:test && npm run go:vuln",
    "workflows:actionlint": "go run github.com/rhysd/actionlint/cmd/actionlint@v1.7.12",
    "workflows:zizmor": "zizmor --persona pedantic --min-severity low --offline .github/workflows",
    "workflows:check": "npm run workflows:actionlint && npm run workflows:zizmor",
    "security:audit": "npm audit --audit-level=high",
    "security:secrets": "go run github.com/zricethezav/gitleaks/v8@v8.30.1 dir . --redact --no-banner && go run github.com/zricethezav/gitleaks/v8@v8.30.1 git --redact --no-banner",
    "security:check": "npm run security:audit && npm run security:secrets"
  },
  "devDependencies": {
    "@commitlint/cli": "21.1.0",
    "@commitlint/config-conventional": "21.1.0",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@eslint/js": "10.0.1",
    "@types/node": "22.20.0",
    "@types/semver": "7.7.1",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/eslint-plugin": "1.6.22",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-node": "0.3.9",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-regexp": "3.1.1",
    "eslint-plugin-unicorn": "71.1.0",
    "glob": "13.0.6",
    "globals": "17.7.0",
    "knip": "6.26.0",
    "markdownlint-cli2": "0.23.0",
    "prettier": "3.9.5",
    "semver": "7.8.5",
    "tar": "7.5.19",
    "tsx": "4.23.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  },
  "dependencies": {
    "@ff-labs/pi-fff": "0.9.6"
  }
}
